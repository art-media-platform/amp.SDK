# Copy to .env.local and fill in the board planet UID.
# The ampd node serving app.www (default port 5193).
VITE_AMP_VAULT_URL=http://localhost:5193
# Base32 UID of the public forum board planet ampd founded with -forums.host.
# ampd logs it at boot: "forums custodian ready: board planet <UID> (public)".
VITE_AMP_PLANET_TAG=
